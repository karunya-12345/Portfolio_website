<style>
  :root{
    --bg:#0e0a1a;
    --surface:#171228;
    --surface-2:#1f1834;
    --border:rgba(255,255,255,0.09);
    --border-strong:rgba(255,255,255,0.18);
    --text:#f1edfb;
    --text-muted:#a89bc7;
    --purple:#a374ff;
    --purple-deep:#7c3aed;
    --purple-dim:rgba(163,116,255,0.14);
    --purple-border:rgba(163,116,255,0.38);
    --radius:16px;
    --maxw:1100px;
  }
  [data-theme="light"]{
    --bg:#faf8ff;
    --surface:#ffffff;
    --surface-2:#f3eefc;
    --border:rgba(20,10,40,0.09);
    --border-strong:rgba(20,10,40,0.18);
    --text:#190f2e;
    --text-muted:#6c5d88;
    --purple:#7c3aed;
    --purple-deep:#5b21b6;
    --purple-dim:rgba(124,58,237,0.08);
    --purple-border:rgba(124,58,237,0.3);
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;background:var(--bg);color:var(--text);
    font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased;
    transition:background .3s ease, color .3s ease;
  }
  ::selection{background:var(--purple-dim);color:var(--text);}
  a{color:inherit;}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 28px;}
  h1,h2,h3{font-family:'Space Grotesk',sans-serif;margin:0;letter-spacing:-0.01em;}
  :focus-visible{outline:2px solid var(--purple);outline-offset:3px;}
  img{max-width:100%;display:block;}

  /* nav */
  .nav{position:fixed;top:0;left:0;right:0;z-index:50;background:color-mix(in srgb, var(--bg) 78%, transparent);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);}
  .nav__inner{max-width:var(--maxw);margin:0 auto;padding:16px 28px;display:flex;align-items:center;justify-content:space-between;gap:20px;}
  .nav__logo{font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;text-decoration:none;white-space:nowrap;}
  .nav__right{display:flex;align-items:center;gap:30px;min-width:0;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;}
  .nav__right::-webkit-scrollbar{display:none;}
  .theme-control{display:flex;align-items:center;gap:10px;flex:none;}
  .theme-control__label{font-size:13px;color:var(--text-muted);}
  .switch{position:relative;width:42px;height:24px;background:var(--surface-2);border:1px solid var(--border-strong);border-radius:999px;cursor:pointer;flex:none;padding:0;}
  .switch__knob{position:absolute;top:2px;left:2px;width:18px;height:18px;border-radius:50%;background:var(--purple);transition:transform .25s ease;}
  [data-theme="light"] .switch__knob{transform:translateX(18px);}
  .nav__links{display:flex;align-items:center;gap:24px;list-style:none;margin:0;padding:0;flex:none;}
  .nav__links a{font-size:14px;color:var(--text-muted);text-decoration:none;white-space:nowrap;transition:color .2s ease;}
  .nav__links a:hover{color:var(--text);}

  /* hero */
  .hero{position:relative;min-height:92vh;display:flex;align-items:center;padding:130px 0 60px;overflow:hidden;}
  .hero__bg{position:absolute;inset:0;background-image:url('data:image/jpeg;base64,<...your embedded photo, omitted here for length...>');background-size:cover;background-position:center;z-index:0;}
  .hero__overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg, rgba(14,10,26,0.55) 0%, rgba(14,10,26,0.82) 65%, var(--bg) 100%), linear-gradient(120deg, rgba(124,58,237,0.5), rgba(14,10,26,0.35));}
  .hero__inner{position:relative;z-index:2;}
  .hero__eyebrow{font-size:14px;font-weight:500;letter-spacing:.03em;color:#d9c7ff;margin:0 0 16px;}
  .hero h1{font-size:clamp(36px,6vw,60px);line-height:1.06;font-weight:700;color:#ffffff;}
  .hero h1 .accent{background:linear-gradient(90deg,#c9a3ff,#7c3aed);-webkit-background-clip:text;background-clip:text;color:transparent;}
  .hero__bio{font-size:16.5px;line-height:1.8;color:rgba(255,255,255,0.78);max-width:560px;margin:22px 0 0;}
  .hero__cta{display:flex;gap:16px;flex-wrap:wrap;margin-top:36px;}

  .scroll-cue{position:absolute;bottom:34px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;z-index:2;color:rgba(255,255,255,0.7);text-decoration:none;}
  .scroll-cue span{font-size:11.5px;letter-spacing:.06em;}
  .scroll-cue svg{animation:drift 1.8s ease-in-out infinite;}
  @keyframes drift{0%,100%{transform:translateY(0);}50%{transform:translateY(6px);}}

  /* sections generic */
  .section{padding:96px 0;border-top:1px solid var(--border);}
  .section__head{margin-bottom:44px;text-align:center;}
  .section__head h2{font-size:clamp(26px,4vw,36px);font-weight:600;}
  .section__head p{color:var(--text-muted);font-size:15px;margin:10px 0 0;}

  /* buttons */
  .btn{font-family:'Inter',sans-serif;font-size:14px;font-weight:500;display:inline-flex;align-items:center;gap:9px;padding:13px 22px;border-radius:11px;text-decoration:none;border:1px solid var(--border-strong);transition:all .2s ease;cursor:pointer;}
  .btn--primary{background:linear-gradient(90deg,var(--purple-deep),var(--purple));color:#ffffff;border:none;}
  .btn--primary:hover{filter:brightness(1.08);}
  .btn--ghost-light{background:rgba(255,255,255,0.08);color:#ffffff;border:1px solid rgba(255,255,255,0.4);backdrop-filter:blur(6px);}
  .btn--ghost-light:hover{background:rgba(255,255,255,0.16);}
  .btn--ghost{color:var(--text);background:transparent;border:1px solid var(--border-strong);}
  .btn--ghost:hover{background:var(--surface-2);}

  /* about */
  .about__grid{display:grid;grid-template-columns:1.3fr 1fr;gap:26px;align-items:start;}
  .card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:32px;}
  .bio-card p{font-size:15.5px;line-height:1.85;color:var(--text-muted);margin:0;}
  .bio-card p:not(:last-child){margin-bottom:16px;}
  .bio-card p:first-child{color:var(--text);}
  .skills__group:not(:last-child){margin-bottom:24px;}
  .skills__label{font-size:12px;font-weight:500;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;margin:0 0 12px;}
  .skills__pills{display:flex;flex-wrap:wrap;gap:8px;}
  .pill{font-size:13px;padding:6px 13px;border-radius:999px;background:var(--purple-dim);color:var(--purple);}

  /* education */
  .education__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  .edu-card{background:var(--surface);border:1.5px solid var(--purple-border);border-radius:var(--radius);padding:30px 22px;text-align:center;}
  .edu-card h3{font-size:18.5px;font-weight:600;margin-bottom:18px;line-height:1.3;}
  .edu-row{display:flex;align-items:center;justify-content:center;gap:8px;font-size:13.5px;color:var(--text-muted);margin-bottom:8px;}
  .edu-row:last-child{margin-bottom:0;}
  .edu-row svg{flex:none;color:var(--purple);}

  /* experience */
  .exp-card{display:flex;gap:32px;align-items:stretch;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:32px;}
  .exp-card__text{flex:1.3;}
  .exp-card__role{font-size:20px;font-weight:600;margin:0 0 6px;}
  .exp-card__company{font-size:14px;color:var(--purple);margin:0 0 4px;font-weight:500;}
  .exp-card__dates{font-size:13px;color:var(--text-muted);margin:0 0 20px;}
  .exp-card ul{margin:0;padding-left:20px;}
  .exp-card li{font-size:15px;line-height:1.85;color:var(--text-muted);}
  .exp-card li:not(:last-child){margin-bottom:10px;}
  .exp-card li::marker{color:var(--purple);}
  .exp-card__media{flex:1;border-radius:12px;overflow:hidden;min-height:240px;}
  .exp-card__media img{width:100%;height:100%;object-fit:cover;}

  /* projects */
  .projects__grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
  .proj-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:transform .25s ease, border-color .25s ease;}
  .proj-card:hover{transform:translateY(-4px);border-color:var(--purple-border);}
  .proj-card__img{width:100%;aspect-ratio:16/10;overflow:hidden;}
  .proj-card__img img{width:100%;height:100%;object-fit:cover;}
  .proj-card__body{padding:24px;}
  .proj-card__tag{display:inline-block;font-size:11.5px;font-weight:500;color:var(--purple);background:var(--purple-dim);padding:4px 11px;border-radius:7px;margin-bottom:13px;}
  .proj-card h3{font-size:18px;font-weight:600;margin-bottom:9px;}
  .proj-card p{font-size:14.5px;line-height:1.65;color:var(--text-muted);margin:0 0 18px;}

  /* contact */
  .contact__head p.lead{color:var(--text-muted);font-size:16px;max-width:480px;margin:10px auto 0;line-height:1.7;}
  .contact-form{max-width:520px;margin:0 auto 56px;text-align:left;}
  .form-row{margin-bottom:18px;}
  .form-row label{display:block;font-size:13px;color:var(--text-muted);margin-bottom:8px;}
  .form-row input,.form-row textarea{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 14px;color:var(--text);font-family:'Inter',sans-serif;font-size:14.5px;resize:vertical;transition:border-color .2s ease;}
  .form-row input:focus,.form-row textarea:focus{border-color:var(--purple);outline:none;}
  .contact-form .btn{width:100%;justify-content:center;border:none;cursor:pointer;}
  .form-note{font-size:12px;color:var(--text-muted);text-align:center;margin:12px 0 0;min-height:16px;}
  .connect{text-align:center;}
  .connect__label{font-size:13px;color:var(--text-muted);margin:0 0 18px;}
  .social-row{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;}

  /* footer */
  .footer-block{border-top:1px solid var(--border);padding:32px 0;text-align:center;}
  .footer-line{font-size:13px;color:var(--text-muted);margin:0 0 10px;}
  .footer-tag{font-family:'Space Grotesk',sans-serif;font-size:14px;color:var(--text);font-weight:500;margin:0 0 10px;}
  .footer-copy{font-size:12px;color:var(--text-muted);margin:0;}

  .reveal{opacity:0;transform:translateY(16px);transition:opacity .6s ease, transform .6s ease;}
  .reveal.in{opacity:1;transform:translateY(0);}

  @media (max-width:760px){
    .about__grid{grid-template-columns:1fr;}
    .education__grid{grid-template-columns:1fr;}
    .projects__grid{grid-template-columns:1fr;}
    .exp-card{flex-direction:column;}
    .nav__inner{padding:14px 20px;}
    .theme-control__label{display:none;}
    .nav__links{gap:14px;}
    .nav__links a{font-size:12.5px;}
  }
  @media (prefers-reduced-motion:reduce){
    html{scroll-behavior:auto;}
    .scroll-cue svg{animation:none;}
    .proj-card:hover{transform:none;}
  }
</style>
</head>
